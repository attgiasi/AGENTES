{
  "name": "gmail-apple-ia-agent",
  "version": "1.0.0",
  "description": "Agente inteligente para Gmail com OpenAI/Gemini, painel web e integração Apple via Siri/Atalhos.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node --experimental-sqlite --no-warnings src/index.js",
    "server": "node --experimental-sqlite --no-warnings src/server.js",
    "auth:gmail": "node --experimental-sqlite --no-warnings src/gmail/auth-cli.js",
    "gmail:check": "node --experimental-sqlite --no-warnings scripts/check-gmail-auth.js",
    "settings:export": "node --experimental-sqlite --no-warnings scripts/export-settings.js",
    "ui:sync": "node --no-warnings scripts/sync-dashboard.js",
    "ui:check": "node --no-warnings scripts/sync-dashboard.js --check",
    "config:validate": "node --experimental-sqlite --no-warnings scripts/validate-config.js",
    "config:summary": "node --experimental-sqlite --no-warnings scripts/print-config-summary.js",
    "config:summary:db": "node --experimental-sqlite --no-warnings scripts/print-config-summary.js --db",
    "check": "node --experimental-sqlite --no-warnings scripts/check-syntax.js && node --no-warnings scripts/sync-dashboard.js --check && node --experimental-sqlite --no-warnings --test"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "googleapis": "^166.0.0"
  }
}
